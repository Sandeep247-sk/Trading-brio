generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String          @id @default(uuid())
  email            String          @unique
  password         String
  name             String
  role             Role            @default(TRADER)
  twoFactorEnabled Boolean         @default(false)
  twoFactorSecret  String?
  avatarUrl        String?
  isActive         Boolean         @default(true)
  deletedAt        DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  accounts         Account[]
  auditLogs        AuditLog[]
  behaviorScores   BehaviorScore[]
  ruleViolations   RuleViolation[]
  strategies       Strategy[]
  sessions         UserSession[]

  @@index([email])
  @@index([role])
  @@map("users")
}

model UserSession {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("user_sessions")
}

model Account {
  id                 String          @id @default(uuid())
  userId             String
  name               String
  brokerName         String?
  accountType        AccountType     @default(LIVE)
  platform           TradingPlatform @default(OTHER)
  accountNumber      String?
  startingBalance    Decimal         @db.Decimal(18, 2)
  currentBalance     Decimal         @db.Decimal(18, 2)
  currency           String          @default("USD")
  isDefault          Boolean         @default(false)
  maxRiskPerTrade    Decimal?        @db.Decimal(5, 2)
  maxDailyDrawdown   Decimal?        @db.Decimal(5, 2)
  maxWeeklyDrawdown  Decimal?        @db.Decimal(5, 2)
  maxOverallDrawdown Decimal?        @db.Decimal(5, 2)
  maxTradesPerDay    Int?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  user               User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  trades             Trade[]

  @@index([userId])
  @@index([userId, isDefault])
  @@map("accounts")
}

model Trade {
  id                String           @id @default(uuid())
  accountId         String
  pair              String
  date              DateTime
  session           TradingSession
  direction         Direction
  entryPrice        Decimal          @db.Decimal(18, 8)
  stopLoss          Decimal          @db.Decimal(18, 8)
  takeProfit        Decimal          @db.Decimal(18, 8)
  riskPercent       Decimal          @db.Decimal(5, 2)
  result            TradeResult?
  rrAchieved        Decimal?         @db.Decimal(8, 2)
  pnl               Decimal?         @db.Decimal(18, 2)
  notes             String?
  strategyVersionId String?
  deletedAt         DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  violations        RuleViolation[]
  analyses          TradeAnalysis[]
  images            TradeImage[]
  account           Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  strategyVersion   StrategyVersion? @relation(fields: [strategyVersionId], references: [id])

  @@index([accountId, deletedAt, result])
  @@index([accountId, deletedAt, date])
  @@index([accountId, deletedAt, pair, result])
  @@index([accountId, deletedAt, session])
  @@index([accountId, deletedAt, pnl])
  @@index([strategyVersionId])
  @@index([date])
  @@map("trades")
}

model TradeImage {
  id        String    @id @default(uuid())
  tradeId   String
  type      ImageType
  url       String
  key       String
  mimeType  String
  sizeBytes Int
  createdAt DateTime  @default(now())
  trade     Trade     @relation(fields: [tradeId], references: [id], onDelete: Cascade)

  @@index([tradeId])
  @@map("trade_images")
}

model TradeAnalysis {
  id                 String     @id @default(uuid())
  tradeId            String
  matchScore         Int
  executionScore     Int
  disciplineScore    Int
  grade              TradeGrade
  checklist          Json
  mistakes           Json
  suggestions        Json
  detectedViolations Json
  rawResponse        Json
  modelUsed          String
  processingTimeMs   Int?
  createdAt          DateTime   @default(now())
  trade              Trade      @relation(fields: [tradeId], references: [id], onDelete: Cascade)

  @@index([tradeId])
  @@index([createdAt])
  @@map("trade_analyses")
}

model Strategy {
  id        String            @id @default(uuid())
  userId    String
  name      String
  market    Market
  isActive  Boolean           @default(true)
  deletedAt DateTime?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions  StrategyVersion[]

  @@index([userId, deletedAt])
  @@map("strategies")
}

model StrategyVersion {
  id                 String                       @id @default(uuid())
  strategyId         String
  version            Int
  description        String?
  preferredSessions  Json
  higherTimeframes   Json
  entryTimeframes    Json
  entryConditions    Json
  riskRules          Json
  managementRules    Json
  changelog          String?
  isActive           Boolean                      @default(true)
  createdAt          DateTime                     @default(now())
  changeLogs         StrategyChangeLog[]
  performanceHistory StrategyPerformanceHistory[]
  rules              StrategyRule[]
  strategy           Strategy                     @relation(fields: [strategyId], references: [id], onDelete: Cascade)
  trades             Trade[]

  @@unique([strategyId, version])
  @@index([strategyId])
  @@map("strategy_versions")
}

model StrategyRule {
  id          String          @id @default(uuid())
  versionId   String
  category    RuleCategory
  name        String
  description String?
  isRequired  Boolean         @default(true)
  order       Int             @default(0)
  createdAt   DateTime        @default(now())
  version     StrategyVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([versionId])
  @@map("strategy_rules")
}

model StrategyChangeLog {
  id         String          @id @default(uuid())
  versionId  String
  changeType String
  field      String
  oldValue   String?
  newValue   String?
  createdAt  DateTime        @default(now())
  version    StrategyVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([versionId])
  @@map("strategy_change_logs")
}

model StrategyPerformanceHistory {
  id             String          @id @default(uuid())
  versionId      String
  totalTrades    Int             @default(0)
  winRate        Decimal         @default(0) @db.Decimal(5, 2)
  profitFactor   Decimal         @default(0) @db.Decimal(8, 2)
  averageRR      Decimal         @default(0) @db.Decimal(8, 2)
  netProfit      Decimal         @default(0) @db.Decimal(18, 2)
  adherenceScore Decimal         @default(0) @db.Decimal(5, 2)
  executionScore Decimal         @default(0) @db.Decimal(5, 2)
  calculatedAt   DateTime        @default(now())
  version        StrategyVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([versionId])
  @@map("strategy_performance_history")
}

model ViolationCategory {
  id          String          @id @default(uuid())
  name        String          @unique
  description String?
  severity    Severity        @default(MEDIUM)
  createdAt   DateTime        @default(now())
  violations  RuleViolation[]

  @@map("violation_categories")
}

model RuleViolation {
  id          String            @id @default(uuid())
  tradeId     String?
  userId      String
  categoryId  String
  description String
  plImpact    Decimal?          @db.Decimal(18, 2)
  detectedBy  DetectedBy        @default(AI)
  createdAt   DateTime          @default(now())
  category    ViolationCategory @relation(fields: [categoryId], references: [id])
  trade       Trade?            @relation(fields: [tradeId], references: [id])
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([tradeId])
  @@index([categoryId])
  @@map("rule_violations")
}

model BehaviorScore {
  id               String   @id @default(uuid())
  userId           String
  period           String
  periodType       String
  disciplineScore  Decimal  @default(0) @db.Decimal(5, 2)
  complianceScore  Decimal  @default(0) @db.Decimal(5, 2)
  consistencyScore Decimal  @default(0) @db.Decimal(5, 2)
  totalTrades      Int      @default(0)
  calculatedAt     DateTime @default(now())
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, period, periodType])
  @@index([userId, periodType])
  @@map("behavior_scores")
}

model AuditLog {
  id        String      @id @default(uuid())
  userId    String?
  action    AuditAction
  entity    String
  entityId  String?
  details   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime    @default(now())
  user      User?       @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([entity, entityId])
  @@index([action])
  @@map("audit_logs")
}

enum Role {
  TRADER
  ADMIN
}

enum Direction {
  LONG
  SHORT
}

enum TradeResult {
  WIN
  LOSS
  BREAKEVEN
}

enum TradingSession {
  LONDON
  NEW_YORK
  ASIAN
}

enum ImageType {
  BEFORE_ENTRY
  ENTRY
  EXIT
  ANNOTATED
}

enum Market {
  XAUUSD
  FOREX
  INDICES
  CRYPTO
}

enum AccountType {
  DEMO
  LIVE
  PROP_CHALLENGE
  PROP_FUNDED
}

enum TradingPlatform {
  MT4
  MT5
  TRADINGVIEW
  CTRADER
  DXTRADE
  OTHER
}

enum RuleCategory {
  PRE_TRADE
  ENTRY
  EXIT
  RISK
  SESSION
  MANAGEMENT
}

enum TradeGrade {
  A_PLUS
  A
  B
  C
  D
}

enum DetectedBy {
  AI
  MANUAL
  SYSTEM
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  ANALYZE
}
